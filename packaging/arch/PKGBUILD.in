pkgname=fcitx5-vinput
pkgver=@VINPUT_PKGVER@
pkgrel=@VINPUT_PKGREL@
pkgdesc='Offline voice input addon for Fcitx5 with optional OpenAI-compatible postprocess'
arch=('x86_64')
url='@VINPUT_PKGURL@'
license=('GPL3')
options=(!debug)
depends=('curl' 'fcitx5' 'libarchive' 'openssl' 'pipewire' 'qt6-base' 'systemd-libs')
makedepends=('clang' 'cli11' 'cmake' 'mold' 'ninja' 'nlohmann-json' 'pkgconf' 'qt6-tools' 'systemd')
source=('@VINPUT_SOURCE_ARCHIVE@')
sha256sums=('@VINPUT_SOURCE_SHA256@')

_sherpa_onnx_ver=@SHERPA_ONNX_VERSION@
_vosk_ver=@VOSK_VERSION@

build() {
    local src_root="${srcdir}/${pkgname}-${pkgver}"
    export CC=clang
    export CXX=clang++

    # Install pre-built sherpa-onnx for the package build.
    bash "${src_root}/scripts/build-sherpa-onnx.sh" \
        "${_sherpa_onnx_ver}" "${srcdir}/sherpa-onnx-install"

    # Install pre-built vosk for the package build.
    bash "${src_root}/scripts/build-vosk.sh" \
        "${_vosk_ver}" "${srcdir}/sherpa-onnx-install"

    cmake -S "${src_root}" -B "${srcdir}/build" \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_PREFIX_PATH="${srcdir}/sherpa-onnx-install" \
        -DCMAKE_EXE_LINKER_FLAGS=-fuse-ld=mold \
        -DCMAKE_SHARED_LINKER_FLAGS=-fuse-ld=mold \
        -DCMAKE_MODULE_LINKER_FLAGS=-fuse-ld=mold \
        -DVINPUT_PROJECT_VERSION="${pkgver}" \
        -DVINPUT_PACKAGE_RELEASE="${pkgrel}" \
        -DVINPUT_PACKAGE_HOMEPAGE_URL="${url}"
    cmake --build "${srcdir}/build"
}

package() {
    DESTDIR="${pkgdir}" cmake --install "${srcdir}/build"
}
