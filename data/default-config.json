{
  "version": 3,
  "capture_device": "default",
  "registry": {
    "models": [
      {
        "name": "github",
        "urls": [
          "https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/models.json"
        ]
      },
      {
        "name": "gh-proxy",
        "urls": [
          "https://gh-proxy.com/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/models.json"
        ]
      },
      {
        "name": "ghfast",
        "urls": [
          "https://ghfast.top/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/models.json"
        ]
      }
    ],
    "asr_providers": [
      {
        "name": "github",
        "urls": [
          "https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/asr-providers.json"
        ]
      },
      {
        "name": "gh-proxy",
        "urls": [
          "https://gh-proxy.com/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/asr-providers.json"
        ]
      },
      {
        "name": "ghfast",
        "urls": [
          "https://ghfast.top/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/asr-providers.json"
        ]
      }
    ],
    "llm_adaptors": [
      {
        "name": "github",
        "urls": [
          "https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/llm-adaptors.json"
        ]
      },
      {
        "name": "gh-proxy",
        "urls": [
          "https://gh-proxy.com/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/llm-adaptors.json"
        ]
      },
      {
        "name": "ghfast",
        "urls": [
          "https://ghfast.top/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/registry/llm-adaptors.json"
        ]
      }
    ],
    "i18n": [
      {
        "locale": "zh_CN",
        "urls": [
          "https://raw.githubusercontent.com/xifan2333/vinput-registry/main/i18n/zh_CN.json",
          "https://gh-proxy.com/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/i18n/zh_CN.json",
          "https://ghfast.top/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/i18n/zh_CN.json"
        ]
      },
      {
        "locale": "en_US",
        "urls": [
          "https://raw.githubusercontent.com/xifan2333/vinput-registry/main/i18n/en_US.json",
          "https://gh-proxy.com/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/i18n/en_US.json",
          "https://ghfast.top/https://raw.githubusercontent.com/xifan2333/vinput-registry/main/i18n/en_US.json"
        ]
      }
    ]
  },
  "default_language": "zh",
  "llm": {
    "providers": [],
    "adaptors": []
  },
  "asr": {
    "active_provider": "sherpa-onnx",
    "normalize_audio": true,
    "vad": {
      "enabled": true
    },
    "providers": [
      {
        "name": "sherpa-onnx",
        "type": "local",
        "builtin": true,
        "timeout_ms": 15000
      },
      {
        "name": "elevenlabs",
        "type": "command",
        "builtin": true,
        "command": "python3",
        "args": [
          "${VINPUT_ASR_PROVIDER_DIR}/elevenlabs_speech_to_text.py"
        ],
        "env": {},
        "timeout_ms": 60000
      },
      {
        "name": "openai-compatible",
        "type": "command",
        "builtin": true,
        "command": "python3",
        "args": [
          "${VINPUT_ASR_PROVIDER_DIR}/openai_compatible_speech_to_text.py"
        ],
        "env": {
          "OPENAI_COMPATIBLE_ASR_URL": "https://api.openai.com/v1/audio/transcriptions",
          "OPENAI_COMPATIBLE_ASR_MODEL": "gpt-4o-mini-transcribe"
        },
        "timeout_ms": 60000
      },
      {
        "name": "doubao",
        "type": "command",
        "builtin": true,
        "command": "python3",
        "args": [
          "${VINPUT_ASR_PROVIDER_DIR}/doubao_speech_to_text.py"
        ],
        "env": {
          "DOUBAO_ASR_RESOURCE_ID": "volc.bigasr.auc_turbo",
          "DOUBAO_ASR_MODEL_NAME": "bigmodel"
        },
        "timeout_ms": 60000
      }
    ]
  },
  "scenes": {
    "active_scene": "__raw__",
    "definitions": [
      {
        "id": "__raw__",
        "label": "__label_raw__",
        "candidate_count": 0,
        "builtin": true
      },
      {
        "id": "__command__",
        "label": "__label_command__",
        "prompt": "# Command Mode Prompt\n\n## Role\n\nYou are an assistant that applies a spoken command to the user-provided text.\n\n## Context\n\n- The user message is the source text to operate on.\n- The spoken command may contain ASR errors.\n- The spoken command is appended at runtime in the `## Task` section.\n\n## Task\n",
        "builtin": true
      }
    ]
  }
}
